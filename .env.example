# ================================================
# VeriFace AI — Environment Variables
# Copy this file to .env and fill in the values
# ================================================

# App
APP_NAME="VeriFace AI"
APP_VERSION="2.0.0"
ENVIRONMENT=development

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./verifaceai.db

# Model Paths (optional — uses demo mode if not found)
EFFICIENTNET_MODEL_PATH=models/efficientnet_b4.h5
XCEPTION_MODEL_PATH=models/xception.h5
VIT_MODEL_PATH=models/vit_b16.pt

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_PORT=8501
MAX_UPLOAD_SIZE_MB=500

# Feature Flags
ENABLE_WEBCAM=true
ENABLE_AUDIO_ANALYSIS=true
ENABLE_PDF_REPORTS=true
DEMO_MODE=true
